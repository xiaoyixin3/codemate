# Copy these names into your OS, IDE run configuration, or deployment secret store.
# This template intentionally contains no real credentials.
DEEPSEEK_API_KEY=
DEEPSEEK_API_HOST=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
LANGCHAIN4J_ENABLED=true
LANGCHAIN4J_FALLBACK_ENABLED=true
AGENT_TEMPERATURE=0.2
AGENT_TIMEOUT_SECONDS=120
AGENT_MEMORY_MAX_MESSAGES=20
AGENT_MAX_TOOL_ROUND_TRIPS=3
AGENT_LOG_REQUESTS=false
AGENT_LOG_RESPONSES=false
# OpenAI-compatible Embedding service used by the site-knowledge RAG pipeline.
RAG_ENABLED=false
EMBEDDING_API_HOST=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=
OPENAI_GPT4_API_KEY=
XUNFEI_APP_ID=
XUNFEI_API_KEY=
XUNFEI_API_SECRET=
DOUBAO_API_KEY=
DOUBAO_ENDPOINT=
JWT_SECRET=
CODEMATE_SECURITY_SALT=
DB_USERNAME=
DB_PASSWORD=
DB_MASTER_USERNAME=
DB_MASTER_PASSWORD=
DB_SLAVE_USERNAME=
DB_SLAVE_PASSWORD=
REDIS_PASSWORD=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
RABBITMQ_USERNAME=
RABBITMQ_PASSWORD=
