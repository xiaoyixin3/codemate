# Copy to deploy/.env on the production server. Do not commit deploy/.env.
DB_USERNAME=codemate
DB_PASSWORD=replace-with-a-strong-database-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-strong-root-password
REDIS_PASSWORD=replace-with-a-strong-redis-password
JWT_SECRET=replace-with-at-least-32-random-characters
PAICODING_SECURITY_SALT=replace-with-a-random-salt
SITE_HOST=http://your-server-address
STATIC_RESOURCE_HOST=http://your-server-address
